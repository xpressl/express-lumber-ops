# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/express_lumber_ops?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# S3/MinIO (File Storage)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="express-lumber-ops"
S3_REGION="us-east-1"

# Twilio (SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Resend (Email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="ops@expresslumber.com"

# Google Maps / HERE Maps
GOOGLE_MAPS_API_KEY=""
HERE_MAPS_API_KEY=""

# Anthropic (AI extraction + vision)
ANTHROPIC_API_KEY=""
